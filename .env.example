# Django
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173
JWT_ACCESS_TOKEN_MINUTES=30
JWT_REFRESH_TOKEN_DAYS=7

# PostgreSQL
POSTGRES_DB=smart_ai_crm
POSTGRES_USER=smart_ai_crm
POSTGRES_PASSWORD=smart_ai_crm
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Frontend
VITE_API_BASE_URL=http://localhost:8000/api

# AI providers
# OpenAI: Get a free API key at https://platform.openai.com/api-keys (free tier available)
OPENAI_API_KEY=
# LangChain / LangSmith tracing (optional, free at https://smith.langchain.com)
LANGCHAIN_API_KEY=

# Integrations (all optional — CRM works fully without these)
# Google Workspace OAuth: https://console.cloud.google.com (free)
GOOGLE_WORKSPACE_CLIENT_ID=
# Microsoft 365 OAuth: https://portal.azure.com (free)
MICROSOFT_365_CLIENT_ID=
# WhatsApp Business: https://developers.facebook.com/docs/whatsapp (free sandbox)
WHATSAPP_BUSINESS_TOKEN=
# Twilio SMS/WhatsApp: https://www.twilio.com (free trial credit available)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Stripe payments: https://dashboard.stripe.com (test mode is free)
STRIPE_SECRET_KEY=
# Razorpay payments: https://dashboard.razorpay.com (test mode is free)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
